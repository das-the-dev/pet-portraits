# ─────────────────────────────────────────────────────────────
# PAYMENT SETUP (optional — the site works without it)
#
# To accept real payments:
#   1. Make a free account at https://stripe.com
#   2. In the Stripe Dashboard, go to Developers → API keys
#   3. Copy your "Secret key" and paste it below
#   4. Rename this file from  .env.example  to  .env.local
#   5. Restart the dev server (npm run dev)
#
# Until you do this, the commission form will simply email you the
# request instead of taking payment — so you never lose a customer.
# ─────────────────────────────────────────────────────────────

# Your Stripe secret key (starts with sk_test_... while testing)
STRIPE_SECRET_KEY=

# Your live website address, used for payment redirects.
# Locally you can leave this as-is.
NEXT_PUBLIC_SITE_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────
# AUTOMATIC EMAIL NOTIFICATIONS (free)
#
# This makes the website email you the moment someone submits the
# commission form — the customer doesn't have to send anything.
#
#   1. Go to https://web3forms.com
#   2. Type in your email (hadassahdavis@icloud.com) to get a free
#      "Access Key" — they'll show it on screen / email it to you.
#   3. Paste that key below.
#   4. Rename this file to  .env.local  and restart (npm run dev).
#
# Free plan covers 250 requests/month. The key is safe to be public.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=


# ─────────────────────────────────────────────────────────────
# PHOTO UPLOADS (free, via Cloudinary)
#
# Lets a customer's uploaded pet photo reach you as a clickable link
# inside your notification email — automatically.
#
#   1. Make a free account at https://cloudinary.com
#   2. On your dashboard, copy your "Cloud name" → paste below.
#   3. Settings (gear) → Upload → Upload presets → "Add upload preset"
#        - Set "Signing Mode" to UNSIGNED
#        - Save, then copy the preset name → paste below.
#   4. Restart (npm run dev).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
